# PostgreSQL (produção EasyPanel: postgresql://user:senha@sidb:5432/sintel)
# Em senha, troque @ por %40 na URL
DATABASE_URL="postgresql://root:password@localhost:5432/sintel"

# SQLite (desenvolvimento local, se preferir): file:./dev.db

# Chave para JWT (dono) - gerar em produção (mín. 32 caracteres)
JWT_SECRET=your-secret-at-least-32-chars-long

# URL base do site (para montar link do cliente e link de redefinição de senha)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Integração Google Agenda (OAuth conta única da empresa)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google-calendar/callback

# E-mail (Esqueci a senha) - deixado para depois (ex.: Poste.io no EasyPanel).
# Quando configurar: RESEND_API_KEY ou adaptar lib/email.ts para SMTP/Poste.io.
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Soluções Inteligentes <noreply@seudominio.com.br>
