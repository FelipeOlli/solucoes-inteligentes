generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FormaPagamento {
  DINHEIRO
  PIX
  CREDITO
  DEBITO
}

enum GoogleSyncState {
  PENDING_CREATE
  PENDING_UPDATE
  PENDING_DELETE
  IN_SYNC
  ERROR
}

enum TipoObrigacaoContabil {
  DEFIS
  PGDAS
  RAIS_ESOCIAL
  ALVARA
  CERTIFICADO_DIGITAL
  OUTRO
}

enum PeriodicidadeObrigacao {
  MENSAL
  ANUAL
  UNICA
}

enum StatusObrigacaoContabil {
  PENDENTE
  EM_DIA
  VENCENDO
  VENCIDO
  CONCLUIDO
}

enum CategoriaDocumentoContabil {
  BOLETO
  COMPROVANTE
  CERTIFICADO
  OUTRO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  passwordResets PasswordResetToken[]
  comentariosContabeis ComentarioContabil[]
  documentosContabeis DocumentoContabil[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   // hash do token (nunca armazenar o token em claro)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime? // preenchido ao usar (único uso)
  createdAt DateTime @default(now())
  @@index([tokenHash])
  @@index([userId, createdAt])
}

model ClientToken {
  id        String   @id @default(cuid())
  token     String   @unique
  clienteId  String
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Cliente {
  id           String    @id @default(cuid())
  nome         String    // Cliente (razão social ou nome da pessoa)
  nomeContato  String?   // Nome da pessoa do telefone (contato responsável)
  email        String    @unique
  telefone     String    @unique
  logradouro   String?
  bairro       String?
  cidade       String?
  uf           String?
  cep          String?
  observacoes  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  servicos     Servico[]
  clientTokens ClientToken[]
}

model CategoriaServico {
  id        String    @id @default(cuid())
  nome      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  servicos  Servico[]
}

model Servico {
  id                  String              @id @default(cuid())
  codigo              String              @unique
  clienteId           String
  cliente             Cliente             @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  categoriaId         String?
  categoria           CategoriaServico?   @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  tipoServico         String?
  descricao           String
  statusAtual         String              @default("ABERTO")
  dataAbertura        DateTime
  dataAgendamento     DateTime?
  dataConclusao       DateTime?
  prazoEstimado       DateTime?
  valorEstimado       Float?
  enderecoServico     String?
  contatoPreferencial String?
  imagens             String?
  formaPagamento      FormaPagamento?
  googleEventId       String?             @unique
  googleEtag          String?
  googleUpdatedAt     DateTime?
  googleSyncState     GoogleSyncState?    @default(IN_SYNC)
  googleLastError     String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  statusHist          StatusHist[]
  notas               Nota[]
  agendaSyncJobs      AgendaSyncQueue[]
}

model GoogleCalendarIntegration {
  id                  String   @id @default(cuid())
  provider            String   @default("google")
  accountEmail        String?
  calendarId          String   @default("primary")
  accessToken         String
  refreshToken        String
  tokenType           String?
  scope               String?
  expiryDate          DateTime?
  watchChannelId      String?
  watchResourceId     String?
  watchExpiresAt      DateTime?
  nextSyncToken       String?
  lastSyncedAt        DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([provider])
}

model AgendaSyncQueue {
  id          String   @id @default(cuid())
  servicoId   String
  servico     Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  action      String
  payload     String?
  attempts    Int      @default(0)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([processedAt, createdAt])
  @@index([servicoId, createdAt])
}

model StatusHist {
  id             String   @id @default(cuid())
  servicoId      String
  servico        Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  statusAnterior String?
  statusNovo     String
  idAutor        String
  createdAt      DateTime @default(now())
}

model Nota {
  id              String   @id @default(cuid())
  servicoId       String
  servico         Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  conteudo        String
  visivelCliente  Boolean
  idAutor         String
  createdAt       DateTime @default(now())
}

model ObrigacaoContabil {
  id                String                  @id @default(cuid())
  nome              String
  tipo              TipoObrigacaoContabil
  periodicidade     PeriodicidadeObrigacao
  proximoVencimento DateTime
  status            StatusObrigacaoContabil @default(PENDENTE)
  observacao        String?
  ativo             Boolean                 @default(true)
  calendarioEventId String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  documentos        DocumentoContabil[]
  comentarios       ComentarioContabil[]

  @@index([proximoVencimento])
  @@index([status, proximoVencimento])
}

model DocumentoContabil {
  id            String                    @id @default(cuid())
  obrigacaoId   String
  obrigacao     ObrigacaoContabil         @relation(fields: [obrigacaoId], references: [id], onDelete: Cascade)
  categoria     CategoriaDocumentoContabil
  nomeOriginal  String
  arquivoUrl    String
  mimeType      String?
  tamanhoBytes  Int?
  competenciaRef String?
  dataDocumento DateTime?
  createdAt     DateTime                  @default(now())
  uploadedBy    String
  uploader      User                      @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([obrigacaoId, createdAt])
  @@index([categoria, createdAt])
}

model ComentarioContabil {
  id          String           @id @default(cuid())
  obrigacaoId String
  obrigacao   ObrigacaoContabil @relation(fields: [obrigacaoId], references: [id], onDelete: Cascade)
  conteudo    String
  createdAt   DateTime         @default(now())
  autorId     String
  autor       User             @relation(fields: [autorId], references: [id], onDelete: Restrict)

  @@index([obrigacaoId, createdAt])
}

// ─── Módulo Documentos Fiscais ───────────────────────────────────────────────

enum TipoDocumentoFiscal {
  DAS
  DARF_MAED
  PGDAS_D_RECIBO
  DEFIS_RECIBO
  NOTIFICACAO_MAED
  RELATORIO_SITUACAO
  OUTROS
}

enum StatusProcessamentoFiscal {
  PENDENTE
  PROCESSANDO
  PROCESSADO
  PROCESSADO_COM_AVISOS
  ERRO
  MANUAL
}

enum RegimeTributario {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
}

enum PorteEmpresa {
  MEI
  ME
  EPP
}

enum TipoObrigacaoFiscal {
  PGDAS_D
  DAS
  DEFIS
  MAED
}

enum NaturezaObrigacao {
  DECLARACAO
  PAGAMENTO
  MULTA
}

enum StatusObrigacaoFiscal {
  PENDENTE
  ATRASADA
  CUMPRIDA
  CUMPRIDA_ATRASO
  CANCELADA
}

model EmpresaFiscal {
  id          String           @id @default(cuid())
  cnpj        String           @unique
  razaoSocial String
  regime      RegimeTributario @default(SIMPLES_NACIONAL)
  porte       PorteEmpresa     @default(ME)
  ativo       Boolean          @default(true)
  documentos  DocumentoFiscal[]
  obrigacoes  ObrigacaoFiscal[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([cnpj])
}

model DocumentoFiscal {
  id                  String                    @id @default(cuid())
  empresaFiscalId     String
  empresaFiscal       EmpresaFiscal             @relation(fields: [empresaFiscalId], references: [id], onDelete: Cascade)
  tipoDocumento       TipoDocumentoFiscal
  nomeArquivo         String
  arquivoUrl          String
  tamanhoBytes        Int
  hashArquivo         String
  statusProcessamento StatusProcessamentoFiscal @default(PENDENTE)
  erroProcessamento   String?
  textoExtraido       String?                   @db.Text
  dadosExtraidos      Json?
  competencia         DateTime?
  vencimento          DateTime?
  valorTotal          Decimal?                  @db.Decimal(12, 2)
  numeroDocumento     String?
  obrigacaoId         String?                   @unique
  obrigacao           ObrigacaoFiscal?          @relation(fields: [obrigacaoId], references: [id])
  ativo               Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([empresaFiscalId, tipoDocumento])
  @@index([competencia])
  @@index([hashArquivo])
}

model ObrigacaoFiscal {
  id              String                @id @default(cuid())
  empresaFiscalId String
  empresaFiscal   EmpresaFiscal         @relation(fields: [empresaFiscalId], references: [id], onDelete: Cascade)
  tipo            TipoObrigacaoFiscal
  natureza        NaturezaObrigacao
  competencia     DateTime
  vencimento      DateTime
  status          StatusObrigacaoFiscal @default(PENDENTE)
  dataCumprimento DateTime?
  valorTotal      Decimal?              @db.Decimal(12, 2)
  observacoes     String?
  obrigacaoPaiId  String?
  obrigacaoPai    ObrigacaoFiscal?      @relation("ObrigacaoRelFiscal", fields: [obrigacaoPaiId], references: [id])
  filhas          ObrigacaoFiscal[]     @relation("ObrigacaoRelFiscal")
  documento       DocumentoFiscal?
  ativo           Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([empresaFiscalId, vencimento])
  @@index([status])
}
