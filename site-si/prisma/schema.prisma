generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FormaPagamento {
  DINHEIRO
  PIX
  CREDITO
  DEBITO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  passwordResets PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   // hash do token (nunca armazenar o token em claro)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime? // preenchido ao usar (único uso)
  createdAt DateTime @default(now())
  @@index([tokenHash])
  @@index([userId, createdAt])
}

model ClientToken {
  id        String   @id @default(cuid())
  token     String   @unique
  clienteId  String
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Cliente {
  id           String    @id @default(cuid())
  nome         String    // Cliente (razão social ou nome da pessoa)
  nomeContato  String?   // Nome da pessoa do telefone (contato responsável)
  email        String    @unique
  telefone     String    @unique
  endereco     String?
  observacoes  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  servicos     Servico[]
  clientTokens ClientToken[]
}

model CategoriaServico {
  id        String    @id @default(cuid())
  nome      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  servicos  Servico[]
}

model Servico {
  id                  String              @id @default(cuid())
  codigo              String              @unique
  clienteId           String
  cliente             Cliente             @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  categoriaId         String?
  categoria           CategoriaServico?   @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  tipoServico         String?
  descricao           String
  statusAtual         String              @default("ABERTO")
  dataAbertura        DateTime
  dataAgendamento     DateTime?
  dataConclusao       DateTime?
  prazoEstimado       DateTime?
  valorEstimado       Float?
  enderecoServico     String?
  contatoPreferencial String?
  imagens             String?
  formaPagamento      FormaPagamento?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  statusHist          StatusHist[]
  notas               Nota[]
}

model StatusHist {
  id             String   @id @default(cuid())
  servicoId      String
  servico        Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  statusAnterior String?
  statusNovo     String
  idAutor        String
  createdAt      DateTime @default(now())
}

model Nota {
  id              String   @id @default(cuid())
  servicoId       String
  servico         Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  conteudo        String
  visivelCliente  Boolean
  idAutor         String
  createdAt       DateTime @default(now())
}
